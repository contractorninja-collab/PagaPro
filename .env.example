# Copy to ".env" in this folder (Prisma reads it via prisma.config.ts).

DATABASE_URL="postgresql://pagapro:pagapro@localhost:5432/pagapro"

# Vercel's Supabase integration supplies these automatically. The app uses the
# pooled URL at runtime and the non-pooling URL for migrations when DATABASE_URL is absent.
# POSTGRES_PRISMA_URL="postgresql://..."
# POSTGRES_URL_NON_POOLING="postgresql://..."
# PAGAPRO_DATABASE_SCHEMA=pagapro

# SaaS domains. Example:
# PAGAPRO_ROOT_DOMAIN=pagapro.example
# PAGAPRO_ADMIN_HOST=admin.pagapro.example
# NEXT_PUBLIC_PAGAPRO_ADMIN_PATH=/admin-console
# Then clients use {companySlug}.pagapro.example, or Company.customDomain when configured.
PAGAPRO_ROOT_DOMAIN=
PAGAPRO_ADMIN_HOST=

# Set automatically after `npx prisma db seed`, or set manually / via POST /api/dev/active-company
DEV_DEFAULT_COMPANY_ID=

# Optional: Bearer secret for POST /api/leaves/monthly-accrual with JSON { companyId, periodYear, periodMonth }
LEAVE_ACCRUAL_JOB_SECRET=

# Bootstrap platform admin (backstage console at NEXT_PUBLIC_PAGAPRO_ADMIN_PATH), created by `npx prisma db seed` if none exists.
# If SEED_ADMIN_PASSWORD is empty, a random password is generated and printed once to the seed output.
SEED_ADMIN_EMAIL=admin@pagapro.local
SEED_ADMIN_PASSWORD=

# Blob storage for company assets (templates, generated documents, payslips,
# reports, konfigurime images). Defaults to the local filesystem under
# .local-storage/company-assets — set PAGAPRO_STORAGE_BUCKET (with SUPABASE_URL
# and SUPABASE_SERVICE_ROLE_KEY present) to use a PRIVATE Supabase Storage
# bucket instead. Required on serverless, where the local FS is read-only.
# PAGAPRO_STORAGE_DRIVER forces a driver: local | supabase (optional).
PAGAPRO_STORAGE_BUCKET=
# PAGAPRO_STORAGE_DRIVER=

# DOCX -> PDF conversion (documents module). Tried in order:
# 1. DOCX_TO_PDF_URL — Gotenberg-compatible HTTP service (recommended for production),
#    e.g. http://localhost:3001 (docker run -p 3001:3000 gotenberg/gotenberg:8)
# 2. LibreOffice CLI — auto-detected, or set SOFFICE_PATH to soffice(.exe) explicitly
# 3. Microsoft Word COM automation (Windows with Office installed)
DOCX_TO_PDF_URL=
SOFFICE_PATH=
