// PagaPRO — PostgreSQL schema (Kosovo payroll–oriented, multi-company ready)
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum CurrencyCode {
  EUR // Kosovo operational reality + accounting norm
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum JobTitleStatus {
  ACTIVE
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum CompanyMembershipRole {
  OWNER
  ADMIN
  HR_MANAGER
  ACCOUNTANT
  READ_ONLY
}

enum EmploymentType {
  EMPLOYEE // subject to Kosovo withholding + pension per parameter set
  CONTRACTOR // gross-out; PIT & pension amounts expected to be 0 at entry level
}

enum EmployerPrimacy {
  PRIMARY // progressive ATK brackets (punëdhënës kryesor)
  SECONDARY // flat withholding at source for chosen secondary employer (ATK 10% default)
}

enum SecondaryEmployerPitBase {
  TAXABLE_AFTER_PENSION
  GROSS
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE /// Jo aktiv — nuk është larguar zyrtarisht
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

/// Append-only employment events for HR history & audits (complements EmploymentPeriod segments).
enum EmployeeHistoryEventKind {
  CREATED
  UPDATED
  STATUS_CHANGED
  ARCHIVED
  TERMINATED
}

enum PayrollPeriodStatus {
  DRAFT
  REVIEWED // në shqyrtim — pa ndryshime
  APPROVED // i miratuar për kyçje
  LOCKED // immutable — entries të ngrira
  ARCHIVED // arkiv historik pas kyçjes
}

enum CompensationBasis {
  GROSS_MONTHLY
  TARGET_NET_MONTHLY
}

/// Kosovo Labour Law (Ligji Nr. 03/L-212, Neni 10) contract-duration categories.
enum ContractTermType {
  INDEFINITE
  FIXED_TERM
  SPECIFIC_TASK
}

enum PayrollCorrectionKind {
  NET_ADJUSTMENT
  GROSS_ADJUSTMENT
  TAX_ADJUSTMENT
  PENSION_ADJUSTMENT
  OTHER
}

enum PayrollAdjustmentKind {
  BONUS
  DEDUCTION
  EMPLOYER_CONTRIBUTION
}

enum PayrollDocumentKind {
  REGISTER_WITH_TOTALS
  REGISTER_SIGNATURE_LIST
  EMPLOYEE_PAYSLIP
  PAYSLIPS_PRINT_BUNDLE
}

enum PayrollEntryStatus {
  DRAFT
  FINAL
}

enum PayslipDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum LeaveType {
  PUSHIM_VJETOR
  PUSHIM_MJEKESOR
  PUSHIM_PERSONAL
  PUSHIM_PA_PAGESE
  PUSHIM_LEHONIE
  TJETER
}

/// Kosovo Law 03/L-212 operational sub-types (Art 39 paid events, Art 50 paternity phases, maternity phase labels for payroll hooks).
enum LeaveSubtype {
  NONE
  MARTESE
  VDEKJE_FAMILJARE
  LINDJE_FEMIJE
  DHURIM_GJAKU
  ATERSI_PAGUAR_2_DITE
  ATERSI_PA_PAGESE_JAVE_2
  LEHONI_FAZA_PUNEDHENESI_70
  LEHONI_FAZA_QEVERIA_50
  LEHONI_FAZA_FUNDIT_PA_PAGESE
  /// Lëndim në punë / sëmundje profesionale — jashtë kuotës 20-ditore të pushimit mjekësor të rregullt.
  LENDIM_PUNE_OSE_SEMUNDJE_PROFESIONALE
}

enum LeaveRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AnnualLeaveAccrualMode {
  UPFRONT
  MONTHLY
  STATUTORY_FIRST_YEAR
}

enum AnnualLeaveRoundingMode {
  NONE
  HALF_DAY
  FULL_DAY
}

enum ContractKind {
  EMPLOYMENT
  CONTRACTOR_AGREEMENT
  AMENDMENT
}

/// Universal document family for templates + generation artifacts
enum DocumentCategory {
  CONTRACT
  LEAVE
  TERMINATION
  WARNING
  PAYROLL
  OTHER
}

/// Polymorphic subject pointer (mirrors DocumentCategory)
enum DocumentSubjectKind {
  CONTRACT
  LEAVE
  TERMINATION
  WARNING
  PAYROLL
  OTHER
}

/// Only meaningful when DocumentTemplate.documentCategory = CONTRACT
enum DocumentTemplateSubtype {
  AFAT_I_CAKTUAR // fixed-term
  AFAT_I_PACAKTUAR // open-ended / indefinite
  KONTRATE_SPECIFIKE // specific / special-purpose agreement
  PRAKTIKANT // internship contract (Neni 16), part-time, always fixed-term
}

enum DocumentSourceFormat {
  DOCX
  HTML_LEGACY // historic bodyHtml column
  PDF // reserved — generation pipeline not implemented yet
}

enum TemplateDetectionMode {
  PLACEHOLDER
  BLANK_FIELDS
  MIXED
}

enum DocumentGenerationStatus {
  PENDING
  RENDERING
  SUCCEEDED
  FAILED
}

enum DocumentGenerationArtifactKind {
  PREVIEW
  ARCHIVED_FINAL
}

enum DisciplinaryWarningStatus {
  DRAFT
  ISSUED
  VOID
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  SUPERSEDED
  TERMINATED
}

enum TerminationType {
  LARGIM_VULLNETAR
  PA_PARALAJMERIM
  MARREVESHJE_E_DYANSHME
  NGA_PUNEDHENESI
  MANUAL
}

enum TerminationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  COMPLETED
  CANCELLED
}

enum ReportJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum ReportOutputFormat {
  PDF
  XLSX
  CSV
}

/// Raportet module — catalogued operational exports (stable keys for filters_json validation).
enum ReportType {
  LISTA_PUNONJESVE
  PUNONJES_AKTIVE
  PUNONJES_TE_LARGUAR
  KONTRAKTORE
  PUNONJES_SIPAS_DEPARTAMENTIT
  PUNONJES_ME_DOKUMENTE_QE_MUNGOJNE
  RAPORT_PAGAVE_MUJORE
  LISTA_PAGAVE_ME_SUMA
  LISTA_PER_NENSHKRIM_PA_SUMA
  FINANCE_PAYROLL_WORKBOOK
  ATK_EXPORT_WORKBOOK
  TRUSTI_DHE_TATIMI
  EMPLOYER_TOTAL_COST
  SALARY_ADVANCE_DEDUCTIONS
  PUSHIMET_SIPAS_PUNONJESIT
  PUSHIMET_VJETORE_TE_SHFRYTEZUARA
  PUSHIMET_NE_PRITJE
  PUSHIMET_MJEKESORE
  PUSHIMET_PA_PAGESE
  BALANCA_E_PUSHIMEVE
  CARRY_OVER_LEAVE
  DOKUMENTET_E_GJENERUARA
  KONTRATA_AKTIVE
  KONTRATA_AFER_SKADIMIT
  DOKUMENTET_SIPAS_PUNONJESIT
  TEMPLATES_TE_PERDORURA
  LARGIMET_SIPAS_MUAJIT
  LARGIMET_SIPAS_ARSYEVE
  FINAL_PAYROLL_REPORTS
  DOKUMENTET_E_LARGIMIT
}

enum ReportExportAction {
  GENERATED
  DOWNLOADED
  REGENERATED
  ARCHIVED
  PREVIEWED
}

enum WorkArrangement {
  ON_SITE
  REMOTE
  HYBRID
}

enum EmploymentPeriodReason {
  HIRE
  REHIRE
  TERMINATION
  CORRECTION
}

enum TimelineEventSeverity {
  INFO
  WARNING
  CRITICAL
}

/// Payroll calendar — how the holiday was introduced (HR-visible).
enum CompanyHolidayCategory {
  KOSOVO_OFFICIAL_FIXED
  KOSOVO_OFFICIAL_MOVABLE
  COMPANY_CUSTOM
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
}

enum NotificationTopic {
  CONTRACT_EXPIRING
  PAYROLL_REMINDER
  LEAVE_PENDING
  SYSTEM_ALERT
}

/// Domain-level verbs for HR-readable activity rows (complements AuditLog technical actions).
enum DomainActivityVerb {
  CREATED
  UPDATED
  APPROVED
  REJECTED
  LOCKED
  UNLOCKED
  ARCHIVED
  VOIDED
}

// -----------------------------------------------------------------------------
// Companies & settings
// -----------------------------------------------------------------------------

model Company {
  id        String @id @default(cuid())
  legalName String
  tradeName String?
  slug      String? @unique @db.VarChar(80)
  customDomain String? @unique @db.VarChar(255)

  /// Kosovo Business Registration Number (or successor identifier)
  businessRegistrationNumber String? @unique

  fiscalNumber String? @unique // taxpayer / fiscal reference where applicable (NUI)
  status       CompanyStatus   @default(ACTIVE)

  defaultCurrency CurrencyCode @default(EUR)
  timezone        String       @default("Europe/Belgrade")

  /// Registered / legal profile contact (distinct from letterhead line in CompanySetting)
  email     String?
  phone     String?
  website   String?
  addressLine String?
  city        String?
  postalCode  String?
  country     String? @default("XK")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings             CompanySetting?
  memberships          UserCompanyMembership[]
  departments          Department[]
  jobTitles            JobTitle[]
  employees            Employee[]
  payrolls             Payroll[]
  payrollParameterSets PayrollParameterSet[]
  documentTemplates    DocumentTemplate[]
  contracts            Contract[]
  leaveRequests        LeaveRequest[]
  leaveBalances        LeaveBalance[]
  terminations         Termination[]
  disciplinaryWarnings DisciplinaryWarning[]
  reportDefinitions    ReportDefinition[]
  reportJobs           ReportJob[]
  employeeTimelineEvents EmployeeTimelineEvent[]
  domainActivities       DomainActivity[]
  notificationOutboxes NotificationOutbox[]
  notificationPreferences NotificationPreference[]
  employmentPeriods      EmploymentPeriod[]
  employeeEmploymentHistories EmployeeEmploymentHistory[]
  employeeSalaryChanges  EmployeeSalaryChange[]
  employeeContractAnnexes EmployeeContractAnnex[]

  configuration           CompanyConfiguration?
  authorizedRepresentatives AuthorizedRepresentative[]
  payrollSettings         PayrollSettings?
  companyHolidays         CompanyHoliday[]
  payrollSnapshots        PayrollSnapshot[]
  payrollGeneratedDocs    PayrollGeneratedDocument[]
  payrollCorrections      PayrollCorrection[]
  documentGenerationArtifacts DocumentGenerationArtifact[]
  documentTimelineEvents      DocumentTimelineEvent[]
  leavePolicyParameterSets    LeavePolicyParameterSet[]
  leaveAccrualLedgerEntries   LeaveAccrualLedger[]
  payrollAtkExports           PayrollATKExport[]
  generatedReports            GeneratedReport[]
  reportExportLogs            ReportExportLog[]

  @@index([status])
  @@map("companies")
}

/// Company-wide operational defaults consumed by payroll, documents, and leave flows (tenant-isolated).
model CompanyConfiguration {
  id String @id @default(cuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// Reference minimum wage — payroll validation should prefer active PayrollParameterSet; this is the configured company default.
  minimumSalaryCurrent Decimal? @db.Decimal(14, 2)

  /// Planned / announced minimum from 1 July (or next legal effective date) — used for projections and reminders.
  minimumSalaryFromJuly1 Decimal? @db.Decimal(14, 2)

  /// Total pension / “trust” contribution rate as percent (e.g. 10.0000 = 10%). Engine may split employee/employer from legislation.
  trustContributionPercent Decimal? @db.Decimal(8, 4)

  standardWeeklyHours Decimal? @db.Decimal(6, 2)

  contractReferencePrefix String? @db.VarChar(48)
  payrollPdfPrefix        String? @db.VarChar(48)
  generalDocumentPrefix String? @db.VarChar(48)

  annualLeaveDaysDefault   Decimal? @db.Decimal(6, 2)
  personalLeaveDaysDefault Decimal? @db.Decimal(6, 2)
  /// Ditë pune pushim mjekësor i rregullt në vit kalendarik (parazgjedhje aplikacioni: 20).
  medicalLeaveDaysDefault  Decimal? @db.Decimal(6, 2)
  medicalLeavePolicyNote   String?  @db.Text

  /// Ditë pune javore të kompanisë — baza e kuotës vjetore = workingDaysPerWeek × 4 (parazgjedhje 5 → 20 ditë).
  workingDaysPerWeek Decimal? @db.Decimal(4, 2)
  annualLeaveAccrualMode     AnnualLeaveAccrualMode     @default(MONTHLY)
  annualLeaveRoundingMode    AnnualLeaveRoundingMode    @default(NONE)
  allowNegativeAnnualLeaveBalance Boolean @default(false)

  /// Company-level switches — notification worker filters on these before enqueueing.
  notifyContractExpiring Boolean @default(true)
  notifyPayrollReminders Boolean @default(true)
  notifyLeaveApprovals   Boolean @default(true)
  notifyEmployeeWarnings Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_configurations")
}

/// Legal representatives for signatures / stamps — extensible for multiple signatories per company.
model AuthorizedRepresentative {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  /// Optional link to the employee this representative maps to; job title is sourced from the employee.
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  fullName String
  position String?

  signatureStorageKey String?
  stampStorageKey     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, sortOrder])
  @@index([employeeId])
  @@map("authorized_representatives")
}

model CompanySetting {
  id String @id @default(cuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// Minimum gross monthly salary enforced in app against active LegalParameterSet (stored here as cache optional)
  enforceMinimumSalary Boolean @default(true)

  /// Snapshot preference: payroll uses parameter set effective on period end date
  payrollUseParameterEffectiveOn String @default("PERIOD_END") // PERIOD_END | PERIOD_START

  /// Authorized signatory for contracts ({{authorized_person}})
  authorizedRepresentativeName     String?
  /// Job title / role ({{authorized_position}})
  authorizedRepresentativePosition String?
  /// Future: PNG scan of signature in object storage
  authorizedSignatureStorageKey    String?

  /// Future: stamp image in object storage (company seal)
  authorizedStampStorageKey String?

  /// Tenant-owned logo embedded in newly generated company documents
  companyLogoStorageKey String?

  /// Registered address line(s) for contracts / letters (letterhead; Company.addressLine is legal registry block)
  companyAddressLine String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}

// -----------------------------------------------------------------------------
// Users & multi-company membership (RBAC anchor)
// -----------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  emailVerifiedAt DateTime?
  status       UserStatus @default(INVITED)

  displayName String?
  locale      String      @default("sq")

  /// bcrypt hash; null until the account is provisioned with credentials
  passwordHash       String?
  /// Platform-level super admin (backstage console) — not a per-company role
  isPlatformAdmin    Boolean   @default(false)
  /// Force password rotation on next login (temp passwords issued by admins)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          Session[]
  memberships       UserCompanyMembership[]
  linkedEmployees   Employee[]
  lockedPayrolls    Payroll[]               @relation("PayrollLockedBy")
  reviewedPayrolls  Payroll[]               @relation("PayrollReviewedBy")
  approvedPayrolls  Payroll[]               @relation("PayrollApprovedBy")
  archivedPayrolls  Payroll[]               @relation("PayrollArchivedBy")
  payrollCorrectionsCreated PayrollCorrection[] @relation("PayrollCorrectionCreatedBy")
  payrollSnapshotsCaptured PayrollSnapshot[] @relation("PayrollSnapshotCapturedBy")
  payrollDocumentsGenerated PayrollGeneratedDocument[] @relation("PayrollDocumentGeneratedBy")
  payrollAtkExportsGenerated PayrollATKExport[]       @relation("PayrollAtkExportGeneratedBy")
  auditActors       AuditLog[]              @relation("AuditActor")
  documentTemplateVersionsUploaded DocumentTemplateVersion[] @relation("DocumentTemplateVersionUploadedBy")
  documentArtifactsCreated DocumentGenerationArtifact[] @relation("DocumentArtifactCreatedBy")
  documentTimelineEventsCreated DocumentTimelineEvent[] @relation("DocumentTimelineCreatedBy")
  timelineActorEvents     EmployeeTimelineEvent[]       @relation("TimelineActor")
  salaryChangesMade       EmployeeSalaryChange[]        @relation("SalaryChangeBy")
  contractAnnexesCreated  EmployeeContractAnnex[]       @relation("ContractAnnexBy")
  domainActivitiesAuthored DomainActivity[]              @relation("DomainActivityActor")
  notificationPreferences NotificationPreference[]
  targetedNotifications   NotificationOutbox[]          @relation("NotificationTarget")
  leaveRequestsCreated       LeaveRequest[]             @relation("LeaveCreatedBy")
  terminationsApproved       Termination[]              @relation("TerminationApprovedBy")
  terminationsCreated        Termination[]              @relation("TerminationCreatedBy")
  generatedReports           GeneratedReport[]          @relation("GeneratedReportAuthor")
  reportExportLogsPerformed  ReportExportLog[]         @relation("ReportExportLogActor")

  @@index([status])
  @@map("users")
}

/// Server-side login sessions — cookie stores the raw token, DB stores its sha256 hash.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model UserCompanyMembership {
  id String @id @default(cuid())

  userId    String
  companyId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  role CompanyMembershipRole

  isActive  Boolean   @default(true)
  invitedAt DateTime?
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaveRequestsDecided LeaveRequest[] @relation("LeaveDecidedBy")
  timelineActorMembershipEvents EmployeeTimelineEvent[] @relation("TimelineActorMembership")

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@map("user_company_memberships")
}

// -----------------------------------------------------------------------------
// Org structure & employees
// -----------------------------------------------------------------------------

model Department {
  id   String @id @default(cuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  employmentHistoryRecords EmployeeEmploymentHistory[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("departments")
}

model JobTitle {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title String
  department String?
  level String?

  description      String @db.Text
  responsibilities String? @db.Text
  requirements     String? @db.Text

  status JobTitleStatus @default(ACTIVE)

  createdByUserId String?
  updatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@unique([companyId, title])
  @@index([companyId, status, title])
  @@map("job_titles")
}

model Employee {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  jobTitleId String?
  jobTitleProfile JobTitle? @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)

  /// Optional link if employee signs in to a future portal
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  employmentType EmploymentType
  status         EmploymentStatus @default(ACTIVE)

  workArrangement WorkArrangement @default(ON_SITE)

  employerPrimacy EmployerPrimacy @default(PRIMARY)

  /// Optional hourly contract fields—when set, engine can validate hourly vs monthly minimum
  hourlyRate           Decimal? @db.Decimal(14, 4)
  standardMonthlyHours Decimal? @db.Decimal(8, 2)

  firstName  String
  lastName   String
  /// Numri personal — unique brenda kompanisë
  personalId String

  dateOfBirth DateTime?
  gender      Gender?

  phone String?
  email String?

  hireDate           DateTime
  terminationDate    DateTime?
  terminationReason  String? @db.Text
  jobTitle           String?
  probationMonths    Int?

  /// Contract term (Ligji Nr. 03/L-212, Neni 10-11). contractStartDate defaults to hireDate;
  /// contractEndDate is null for indefinite contracts. Drives annex renewals + expiry.
  contractStartDate DateTime?
  contractEndDate   DateTime?
  contractType      ContractTermType @default(INDEFINITE)
  /// Vendi i punës (Neni 11.4); falls back to the company address when empty.
  workplace         String?

  /// Orët kontraktuale javore (UI default 40)
  weeklyHours Decimal @default(40) @db.Decimal(6, 2)

  /// Stored monthly gross for employees; for contractors, interpret as agreed monthly fee baseline (still validated unless exempt)
  baseSalaryMonthly Decimal @db.Decimal(14, 2)

  compensationBasis CompensationBasis @default(GROSS_MONTHLY)

  /// Target monthly net when compensationBasis = TARGET_NET_MONTHLY (engine solves gross / hourly basis from this).
  targetNetMonthly Decimal? @db.Decimal(14, 2)

  /// Contractors may bypass minimum salary checks when true
  exemptFromMinimumSalary Boolean @default(false)

  /// Parapaguesë: apliko pension/trust dhe tatimin në motorin e pagës (kontraktorët = false)
  applyTrust Boolean @default(true)
  applyTax   Boolean @default(true)

  /// Shtetas i huaj me qëndrim të përkohshëm (Ligji 04/L-101: i përjashtuar nga
  /// kontributet e detyrueshme të Trustit; tatimi në paga aplikohet normalisht).
  /// The form auto-sets applyTrust=false when this is enabled; applyTrust stays
  /// the single calculation switch so voluntary contributions remain possible.
  isForeignNational Boolean @default(false)
  /// Skadimi i lejes së qëndrimit — drives the dashboard expiry alert.
  residencePermitExpiryDate DateTime?

  /// Emri i bankës (kopjim i shpejtë për UI; llogaria kryesore në EmployeeBankAccount)
  bankName String?

  /// Legacy convenience IBAN; prefer EmployeeBankAccount for normalized history.
  bankAccountIban String?

  /// Residential / mailing address for contracts ({{employee_address}})
  addressLine    String?
  addressCity    String?
  addressCountry String? @default("XK")

  internalNotes    String? @db.Text
  documentsMissing Boolean @default(false)

  /// Kosovo leave law — hazardous roles minimum 30 working days annual (Art 32.3)
  isHazardousPosition Boolean @default(false)
  /// Art 32.4 extra leave eligibility flags (HR-maintained)
  isSingleParent       Boolean @default(false)
  hasDisability        Boolean @default(false)
  hasChildUnderThree   Boolean @default(false)
  /// Optional anchor when legal tenure ≠ hireDate (collective agreements / transfers)
  leaveTenureAnchorDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollEntries PayrollEntry[]
  contracts      Contract[]
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  terminations   Termination[]
  disciplinaryWarnings DisciplinaryWarning[]
  employmentPeriods    EmploymentPeriod[]
  bankAccounts         EmployeeBankAccount[]
  emergencyContacts    EmployeeEmergencyContact[]
  timelineEvents       EmployeeTimelineEvent[]
  employmentHistoryRecords EmployeeEmploymentHistory[]
  salaryChanges        EmployeeSalaryChange[]
  contractAnnexes      EmployeeContractAnnex[]
  payrollGeneratedDocs PayrollGeneratedDocument[]
  payrollInclusions    PayrollIncludedEmployee[]
  payrollCorrections   PayrollCorrection[]
  documentGenerationArtifacts DocumentGenerationArtifact[]
  documentTimelineEvents      DocumentTimelineEvent[]
  leaveAccrualLedgerEntries   LeaveAccrualLedger[]
  authorizedRepresentatives   AuthorizedRepresentative[]

  @@unique([companyId, personalId])
  @@index([companyId, lastName, firstName])
  @@index([companyId])
  @@index([jobTitleId])
  @@index([companyId, status])
  @@index([companyId, employmentType])
  @@index([companyId, email])
  @@index([email])
  @@index([userId])
  @@map("employees")
}

/// Effective-dated compensation-change history — one row per salary/basis change (audit of raises).
model EmployeeSalaryChange {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  /// When the new compensation takes effect (hire date for the initial record).
  effectiveFrom DateTime

  /// Null for the initial (hire) record; otherwise the prior monthly gross.
  previousBaseSalary Decimal? @db.Decimal(14, 2)
  newBaseSalary      Decimal  @db.Decimal(14, 2)

  compensationBasis CompensationBasis @default(GROSS_MONTHLY)
  targetNetMonthly  Decimal?          @db.Decimal(14, 2)

  reason String? @db.Text

  changedById String?
  changedBy   User?   @relation("SalaryChangeBy", fields: [changedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId, employeeId, effectiveFrom(sort: Desc)])
  @@index([companyId])
  @@map("employee_salary_changes")
}

/// Issued contract amendment (Aneks Kontratë, Ligji Nr. 03/L-212 Neni 10-11, 17-19).
/// Each row records what changed (changesJson) plus a snapshot of the Neni-11 elements at
/// issue time, so the next annex diffs against this snapshot. The DOCX is rendered on demand.
model EmployeeContractAnnex {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  /// Sequential per employee (Aneks nr. 1, 2, …).
  annexNumber Int

  /// When the amendment takes effect.
  effectiveDate DateTime

  /// Which categories changed: e.g. ["SALARY","JOB_TITLE","HOURS","CONTRACT_TERM"].
  changeCategories String[]

  /// Array of { field, label, from, to } describing each change, as rendered in the document.
  changesJson Json

  /// Snapshot of the Neni-11 elements at issue time (the baseline the next annex diffs against).
  snapshotJobTitle        String?
  snapshotJobDescription  String? @db.Text
  snapshotDepartment      String?
  snapshotWorkplace       String?
  snapshotWeeklyHours     Decimal? @db.Decimal(6, 2)
  snapshotBaseSalary      Decimal? @db.Decimal(14, 2)
  snapshotContractStart   DateTime?
  snapshotContractEnd     DateTime?
  snapshotContractType    ContractTermType?

  createdById String?
  createdBy   User?   @relation("ContractAnnexBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([employeeId, annexNumber])
  @@index([companyId, employeeId])
  @@index([companyId])
  @@map("employee_contract_annexes")
}

