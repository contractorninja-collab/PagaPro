  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  capturedAt DateTime @default(now())

  capturedByUserId String?
  capturedBy       User?   @relation("PayrollSnapshotCapturedBy", fields: [capturedByUserId], references: [id], onDelete: SetNull)

  payload Json

  checksum String?

  @@index([companyId])
  @@map("payroll_snapshots")
}

model PayrollGeneratedDocument {
