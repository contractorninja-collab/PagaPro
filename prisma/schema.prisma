// -----------------------------------------------------------------------------
// Kosovo-oriented payroll parameters (versioned, effective-dated)
// -----------------------------------------------------------------------------

/// Company-specific overrides layered on national defaults (national rows companyId = null optional — here scoped per company for simplicity & tenancy)
model PayrollParameterSet {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  effectiveFrom DateTime // inclusive; find active set where effectiveFrom <= anchor date
  effectiveTo   DateTime? // exclusive upper bound; null = open-ended

  label String?

  /// Kosovo legal minimum monthly wage at time of validity (validate Employee.baseSalaryMonthly against this when EmploymentType = EMPLOYEE)
  minimumMonthlyWage Decimal @db.Decimal(14, 2)

  /// Rates as decimal fractions: e.g. 0.05 = 5%
  pensionEmployeeRate Decimal @db.Decimal(8, 6)
  pensionEmployerRate Decimal @db.Decimal(8, 6)

  /// Overtime/holiday/weekend multipliers (structure consumed by payroll calculation engine)
  premiumRules Json?

  /// Defaults: null → engine uses legislation snapshot default (10% for SECONDARY employer)
  secondaryEmployerFlatRate Decimal? @db.Decimal(8, 6)

  secondaryEmployerPitBase SecondaryEmployerPitBase?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pitBrackets PitBracket[]
  payrolls    Payroll[]

  @@index([companyId, effectiveFrom])
  @@index([companyId, effectiveTo])
  @@map("payroll_parameter_sets")
}

/// Progressive / bracket PIT model — Kosovo-aligned shape (bands maintained administratively)
model PitBracket {
  id String @id @default(cuid())

  parameterSetId String
  parameterSet   PayrollParameterSet @relation(fields: [parameterSetId], references: [id], onDelete: Cascade)

  /// Lower bound inclusive (same currency as payroll — EUR)
  fromAmount Decimal @db.Decimal(14, 2)
  /// Upper bound inclusive; use very large upper for top bracket
  toAmount   Decimal @db.Decimal(14, 2)
  /// Marginal rate for this band as decimal fraction
  rate       Decimal @db.Decimal(8, 6)
  /// Flat deductible / allowance per band optional (extend later)
  sequence   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parameterSetId])
  @@map("pit_brackets")
}

// -----------------------------------------------------------------------------
// Monthly payroll shell & entries (locking)
// -----------------------------------------------------------------------------

model Payroll {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// Calendar month payroll identifier (Kosovo monthly cycles)
  year  Int
  month Int // 1-12

  currency CurrencyCode @default(EUR)

  status PayrollPeriodStatus @default(DRAFT)

  /// Weekdays Mon–Fri in month × 8h baseline (full-time); set when spreadsheet generated.
  expectedWorkingDays    Int?
  expectedRegularHours   Decimal? @db.Decimal(10, 2)

  validatedAt       DateTime?
  validationWarnings Json?

  parameterSetId String?
  parameterSet   PayrollParameterSet? @relation(fields: [parameterSetId], references: [id], onDelete: SetNull)

  lockedAt DateTime?
  lockedById String?
  lockedBy   User?    @relation("PayrollLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)

  reviewedAt DateTime?
  reviewedById String?
  reviewedBy   User?    @relation("PayrollReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  approvedAt DateTime?
  approvedById String?
  approvedBy   User?    @relation("PayrollApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  archivedAt DateTime?
  archivedById String?
  archivedBy   User?    @relation("PayrollArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries PayrollEntry[]
  snapshot PayrollSnapshot?
  generatedDocuments PayrollGeneratedDocument[]
  includedEmployees PayrollIncludedEmployee[]
  corrections PayrollCorrection[]
  documentGenerationArtifacts DocumentGenerationArtifact[]
  atkExports    PayrollATKExport[]
  terminationsFinalPayroll Termination[] @relation("TerminationFinalPayroll")

  @@unique([companyId, year, month])
  @@index([companyId, status])
  @@index([companyId, year, month])
  @@index([status])
  @@map("payrolls")
}

model PayrollIncludedEmployee {
  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([payrollId, employeeId])
  @@index([employeeId])
  @@map("payroll_included_employees")
}

model PayrollCorrection {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  kind PayrollCorrectionKind

  amount Decimal @db.Decimal(14, 2)

  reason String @db.Text

  createdByUserId String?
  createdBy       User?   @relation("PayrollCorrectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId, payrollId])
  @@index([payrollId, employeeId])
  @@map("payroll_corrections")
}

model PayrollEntry {
  id String @id @default(cuid())

  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  status PayrollEntryStatus @default(DRAFT)

  /// Frozen classification for audit trail — contractors must have zero withheld fields by application rule
  employmentTypeSnapshot EmploymentType

  employerPrimacySnapshot EmployerPrimacy @default(PRIMARY)

  calendarDaysInMonth Int
  paidDays            Decimal @db.Decimal(6, 2)

  jobTitleSnapshot String?

  compensationBasisSnapshot CompensationBasis?

  contractGrossMonthlySnapshot Decimal? @db.Decimal(14, 2)
  contractNetMonthlySnapshot   Decimal? @db.Decimal(14, 2)

  expectedWorkingDays    Int?
  expectedRegularHours   Decimal? @db.Decimal(10, 2)
  actualRegularHours     Decimal @default(0) @db.Decimal(10, 2)

  paidLeaveHours   Decimal @default(0) @db.Decimal(10, 2)
  sickLeaveHours   Decimal @default(0) @db.Decimal(10, 2)
  unpaidLeaveHours Decimal @default(0) @db.Decimal(10, 2)

  /// Premium hours / amounts (frozen at calculation time)
  overtimeHours   Decimal @default(0) @db.Decimal(10, 2)
  overtimeAmount  Decimal @default(0) @db.Decimal(14, 2)
  holidayHours    Decimal @default(0) @db.Decimal(10, 2)
  holidayAmount   Decimal @default(0) @db.Decimal(14, 2)
  weekendHours    Decimal @default(0) @db.Decimal(10, 2)
  weekendAmount   Decimal @default(0) @db.Decimal(14, 2)
  nightHours      Decimal @default(0) @db.Decimal(10, 2)
  nightAmount     Decimal @default(0) @db.Decimal(14, 2)

  hourlyRate Decimal @default(0) @db.Decimal(14, 6)

  regularPay           Decimal @default(0) @db.Decimal(14, 2)
  paidLeavePay         Decimal @default(0) @db.Decimal(14, 2)
  sickLeavePay         Decimal @default(0) @db.Decimal(14, 2)
  unpaidLeaveDeduction Decimal @default(0) @db.Decimal(14, 2)

  /// Bonuses increase taxable gross after premium stack (engine applies before statutory contributions).
  bonuses Decimal @default(0) @db.Decimal(14, 2)

  /// Parapaguesë / zbritje të tjera (jo parapaguesë e veçantë)
  otherDeductions Decimal @default(0) @db.Decimal(14, 2)

  salaryAdvanceDeduction Decimal @default(0) @db.Decimal(14, 2)

  manualGrossOverride Decimal? @db.Decimal(14, 2)
  manualNetOverride   Decimal? @db.Decimal(14, 2)
  manualGrossReason   String?
  manualNetReason     String?

  notes String? @db.Text

  grossSalary           Decimal @db.Decimal(14, 2)
  taxableIncome         Decimal @db.Decimal(14, 2)
  pitWithheld           Decimal @db.Decimal(14, 2)
  pensionEmployee       Decimal @db.Decimal(14, 2)
  pensionEmployer       Decimal @db.Decimal(14, 2)
  otherEmployerCosts    Decimal @default(0) @db.Decimal(14, 2)
  netPay                Decimal @db.Decimal(14, 2)

  employerTotalCost Decimal @default(0) @db.Decimal(14, 2)

  /// Calculation audit payload (brackets applied, rounding policy version, leave splits, etc.)
  calculationBreakdown Json?

  isLocked Boolean @default(false)

  payslipDeliveryStatus PayslipDeliveryStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adjustments PayrollAdjustment[]

  @@unique([payrollId, employeeId])
  @@index([employeeId])
  @@index([payrollId])
  @@map("payroll_entries")
}

/// Company-scoped payroll operation parameters (loaded by engine — never hardcoded in UI).
model PayrollSettings {
  id String @id @default(cuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  minimumSalaryMonthly Decimal @db.Decimal(14, 2)

  /// Planned minimum (e.g. €500 from July) — engine picks by anchor date vs minimumSalaryScheduledEffectiveFrom
  minimumSalaryScheduledAmount Decimal? @db.Decimal(14, 2)

  minimumSalaryScheduledEffectiveFrom DateTime?

  pensionEmployeePercent Decimal @db.Decimal(8, 6)
  pensionEmployerPercent Decimal @db.Decimal(8, 6)

  overtimeMultiplier Decimal @default(1.3) @db.Decimal(8, 4)
  weekendMultiplier  Decimal @default(1.5) @db.Decimal(8, 4)
  /// Festë — +50% si fundjava (Ligji i Punës i Kosovës)
  holidayMultiplier  Decimal @default(1.5) @db.Decimal(8, 4)

  /// Premium për punë natën — nga PayrollSettings (motor + transparency)
  nightWorkMultiplier Decimal @default(1.3) @db.Decimal(8, 4)

  /// Orë për ditë pune standarde (full-time default 8) — `expected_hours = working_days × hoursPerWorkingDay`
  hoursPerWorkingDay Decimal @default(8) @db.Decimal(6, 2)

  /// Normë javore për përshkrimin e overtime (transparency / politikë — default 40h)
  overtimeWeeklyThresholdHours Decimal @default(40) @db.Decimal(6, 2)

  /// Paga e sëmurë si përqindje e normës (1 = 100 %). Neni 60 i Ligjit të Punës kërkon
  /// 100% — vlerat nën 1 ngrihen automatikisht në dysheme statutore nga motori
  /// (statutorySickLeavePayPercent); mbi 1 lejohet (punëdhënës më bujar).
  sickLeavePayPercent Decimal @default(1) @db.Decimal(8, 6)

  /// Oret maksimum javore të overtime për sinjal paralajmërimi (default 8 sipas kontekstit ligjor)
  overtimeWeeklyCapHours Decimal @default(8) @db.Decimal(8, 2)

  standardWeeklyHours Decimal @db.Decimal(6, 2)

  /// Lista opsionale ISO `YYYY-MM-DD` për festa shtesë (per kompani / përditësime ligjore)
  payrollExtraHolidayDates Json?

  /// ISO `YYYY-MM-DD` që nuk trajtohen si festë zyrtare edhe nëse bien në kalendarin bazë
  payrollExcludedHolidayDates Json?

  /// Për transparency HR (default dritare tipike natë)
  nightWorkPeriodDescription String @default("22:00–06:00") @db.VarChar(96)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payroll_settings")
}

/// Company-scoped yearly holiday calendar — drives expected working-day / regular-hour baselines.
model CompanyHoliday {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// Calendar year this configuration row belongs to (e.g. payroll year 2026).
  calendarYear Int

  /// Observed public holiday date (date-only semantics in UTC).
  observedOn DateTime @db.Date

  name String

  category CompanyHolidayCategory

  /// When false, the date is ignored for capacity / expected-hours calculations (still stored for audit).
  isActive Boolean @default(true)

  /// Stable code for imported Kosovo-fixed templates (dedupe on re-import).
  sourceCode String? @db.VarChar(64)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, calendarYear, observedOn])
  @@index([companyId, calendarYear])
  @@map("company_holidays")
}

model PayrollAdjustment {
  id String @id @default(cuid())

  payrollEntryId String
  payrollEntry   PayrollEntry @relation(fields: [payrollEntryId], references: [id], onDelete: Cascade)

  kind PayrollAdjustmentKind
  label String

  amount Decimal @db.Decimal(14, 2)

  metadata Json?

  createdAt DateTime @default(now())

  @@index([payrollEntryId])
  @@map("payroll_adjustments")
}

/// Immutable payroll archive captured at lock (JSON payload + linked PDF artifacts).
model PayrollSnapshot {
