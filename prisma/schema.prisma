// -----------------------------------------------------------------------------
// Universal documents (templates, versions, artifacts) + employment Contract entity
// -----------------------------------------------------------------------------

/// Logical reusable template library row — DOCX blobs live on DocumentTemplateVersion.
model DocumentTemplate {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String

  /// CONTRACT | LEAVE | TERMINATION | WARNING
  documentCategory DocumentCategory @default(CONTRACT)

  /// Only when documentCategory = CONTRACT (employment / contractor agreement kind)
  contractKind ContractKind?

  /// Only when documentCategory = CONTRACT — legal subtype (afat i caktuar, etc.)
  templateSubtype DocumentTemplateSubtype?

  /// Legacy merge-field HTML — superseded by DOCX versions for new uploads
  bodyHtml String? @db.Text

  isActive Boolean @default(true)

  /// Stable key for Largimet DOCX routing (must match TerminationType); unique per company when set.
  terminationWorkflowKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions  DocumentTemplateVersion[]
  contracts Contract[]
  generationArtifactsFromTemplate DocumentGenerationArtifact[] @relation("GenerationArtifactDocumentTemplate")

  @@index([companyId])
  @@index([companyId, documentCategory])
  @@unique([companyId, terminationWorkflowKey])
  @@map("document_templates")
}

model DocumentTemplateVersion {
  id String @id @default(cuid())

  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  versionNumber Int

  sourceFormat DocumentSourceFormat @default(DOCX)

  sourceStorageKey String
  originalFilename String?

  detectedPlaceholders Json?
  /// Ordered placeholder keys matching underline blanks in the DOCX (1st blank → fields[0], …).
  underlineFieldOrder Json?
  /// How the template encodes fillable fields (tags, blanks, or both).
  detectionMode TemplateDetectionMode?
  /// Detected underscore blank metadata [{ index, xmlPart, originalText, paragraphPreview, suggestedKey? }].
  detectedBlankFields Json?
  /// Admin-confirmed mapping { blankFields: [...], placeholders: [...] }.
  mappingJson Json?
  isMapped Boolean @default(false)
  placeholderSchemaVersion String @default("v1")

  locale String @default("sq")

  isPublished Boolean @default(false)

  changelog String?
  uploadedAt DateTime @default(now())

  uploadedByUserId String?
  uploadedBy       User?   @relation("DocumentTemplateVersionUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  contracts           Contract[]
  generationArtifacts DocumentGenerationArtifact[]

  @@unique([templateId, versionNumber])
  @@index([templateId, isPublished])
  @@map("document_template_versions")
}

model Contract {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  documentTemplateId String?
  documentTemplate   DocumentTemplate? @relation(fields: [documentTemplateId], references: [id], onDelete: SetNull)

  documentTemplateVersionId String?
  documentTemplateVersion   DocumentTemplateVersion? @relation(fields: [documentTemplateVersionId], references: [id], onDelete: SetNull)

  kind   ContractKind
  status ContractStatus @default(DRAFT)

  referenceCode String?

  effectiveDate DateTime
  endDate       DateTime?

  signedAt DateTime?

  storedPdfUrl String?

  jobTitleSnapshot String?
  jobDepartmentSnapshot String?
  jobLevelSnapshot String?
  jobDescriptionSnapshot String? @db.Text
  jobResponsibilitiesSnapshot String? @db.Text
  jobRequirementsSnapshot String? @db.Text
  jobSnapshotGeneratedAt DateTime?

  generationStatus DocumentGenerationStatus @default(PENDING)
  generationError  String?                  @db.Text

  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, status])
  @@index([companyId, status, endDate])
  @@index([documentTemplateVersionId])
  @@map("contracts")
}

/// Append-only immutable rows: never mutate file keys or mergedPayload after insert.
/// Multiple ARCHIVED_FINAL rows per subject are allowed (regenerate = new row + optional supersedes link).
model DocumentGenerationArtifact {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  payrollId String?
  payroll   Payroll? @relation(fields: [payrollId], references: [id], onDelete: SetNull)

  documentTemplateId String?
  documentTemplate   DocumentTemplate? @relation("GenerationArtifactDocumentTemplate", fields: [documentTemplateId], references: [id], onDelete: SetNull)

  subjectKind DocumentSubjectKind
  subjectId   String

  /// Denormalized from template for filtering (must match template.documentCategory)
  documentCategory DocumentCategory

  templateVersionId String
  templateVersion   DocumentTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)

  kind DocumentGenerationArtifactKind

  title           String
  displayFilename String

  mergedPayload Json

  detectedPlaceholderKeys Json?

  /// Optional schema version for mergedPayload shape evolution (e-sign / QR hooks).
  snapshotSchemaVersion String?

  generatedDocxStorageKey String?
  generatedPdfStorageKey  String?

  docxSha256 String?
  pdfSha256  String?

  generationStatus DocumentGenerationStatus @default(SUCCEEDED)
  generationError  String?                  @db.Text

  isArchived Boolean   @default(false)
  archivedAt DateTime?

  supersedesArtifactId String?
  supersedesArtifact   DocumentGenerationArtifact?  @relation("ArtifactSupersedesChain", fields: [supersedesArtifactId], references: [id], onDelete: SetNull)
  supersededByArtifacts  DocumentGenerationArtifact[] @relation("ArtifactSupersedesChain")

  createdAt DateTime @default(now())

  createdByUserId String?
  createdBy       User?   @relation("DocumentArtifactCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  leaveDocuments LeaveDocument[]
  timelineEvents DocumentTimelineEvent[]
  terminationsAsGenerated Termination[] @relation("TerminationGeneratedDocument")

  @@index([subjectKind, subjectId, createdAt])
  @@index([subjectKind, subjectId, kind])
  @@index([templateVersionId])
  @@index([companyId])
  @@index([companyId, documentCategory])
  @@index([companyId, employeeId, createdAt])
  @@index([companyId, createdAt])
  @@index([companyId, payrollId])
  @@index([documentTemplateId])
  @@map("document_generation_artifacts")
}

/// Dokumentet-specific timeline rows (artifact-scoped); pair with EmployeeTimelineEvent when employee-linked.
model DocumentTimelineEvent {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  generatedDocumentId String
  generatedDocument   DocumentGenerationArtifact @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)

  eventType String

  metadata Json? @map("metadata_json")

  createdAt DateTime @default(now())

  createdByUserId String?
  createdBy       User?   @relation("DocumentTimelineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([generatedDocumentId])
  @@index([companyId, employeeId])
  @@map("document_timeline_events")
}

/// Canonical placeholder registry (seeded; merged at runtime with code defaults).
model PlaceholderRegistry {
  id String @id @default(cuid())

  placeholderKey String @unique

  label String

  category String

  exampleValue String?

  description String?

  isRequired Boolean @default(false)

  /// Dot-path hint for resolver (e.g. employee.firstName).
  sourcePath String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("placeholder_registry")
}

model DisciplinaryWarning {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  issuedAt DateTime @default(now())

  summary String @db.Text

  severity String?

  status DisciplinaryWarningStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, status])
  @@map("disciplinary_warnings")
}

// -----------------------------------------------------------------------------
// Leave requests & balances (Pushimet — operational workflow; Kosovo Law 03/L-212 aligned engines)
// -----------------------------------------------------------------------------

/// Effective-dated tenant leave rule parameters (collective agreements, HR overrides).
model LeavePolicyParameterSet {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  effectiveFrom DateTime
  effectiveTo   DateTime?

  minimumAnnualWorkingDays      Decimal @default(20) @db.Decimal(6, 2)
  hazardousMinimumWorkingDays   Decimal @default(30) @db.Decimal(6, 2)
  monthlyAccrualDays            Decimal @default(1.666666666666667) @db.Decimal(14, 9)

  tenureBonusEveryYears       Int     @default(5)
  tenureBonusDaysPerBlock     Decimal @default(1) @db.Decimal(4, 2)
  specialCategoryExtraDays    Decimal @default(2) @db.Decimal(4, 2)

  firstYearGateMonths Int @default(6)

  carryOverExpiryMonth Int @default(6)
  carryOverExpiryDay   Int @default(30)

  splitLeaveMinWorkingDays Int     @default(10)
  enforceSplitLeaveRule    Boolean @default(false)

  blockNegativeBalance       Boolean @default(true)
  warnInsufficientBalance    Boolean @default(true)
  warnSplitLeaveViolation    Boolean @default(true)
  warnCarryOverExpiry        Boolean @default(true)

  enableTenureBonus            Boolean @default(true)
  enableSpecialCategoryExtra   Boolean @default(true)

  collectiveAgreementJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, effectiveFrom])
  @@map("leave_policy_parameter_sets")
}

/// Append-only monthly accrual postings for audit (Art 36 models).
model LeaveAccrualLedger {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  periodYear  Int
  periodMonth Int

  accruedDays Decimal @db.Decimal(10, 4)
  basisJson   Json
  ruleVersion String

  createdAt DateTime @default(now())

  @@index([companyId, employeeId, periodYear, periodMonth])
  @@map("leave_accrual_ledger")
}

model LeaveBalance {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  leaveType LeaveType

  year Int

  yearlyQuota    Decimal @db.Decimal(8, 2)
  usedDays       Decimal @default(0) @db.Decimal(8, 2)
  pendingDays    Decimal @default(0) @db.Decimal(8, 2)
  remainingDays  Decimal @db.Decimal(8, 2)
  carryOverDays  Decimal @default(0) @db.Decimal(8, 2)

  accruedYtd           Decimal @default(0) @db.Decimal(8, 2)
  entitlementFullYear  Decimal? @db.Decimal(8, 2)
  carryIn              Decimal @default(0) @db.Decimal(8, 2)
  carryExpiresAt       DateTime?
  computedFromRuleVersion String?
  breakdown                 Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, employeeId, leaveType, year])
  @@index([companyId, employeeId])
  @@index([companyId, year])
  @@index([employeeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type    LeaveType
  subtype LeaveSubtype @default(NONE)

  status LeaveRequestStatus @default(DRAFT)

  startDate DateTime
  endDate   DateTime

  /// Calendar-inclusive duration (all days in range).
  totalDays Decimal? @db.Decimal(8, 2)

  /// Mon–Fri leave days under metricsRuleVersion (v1 excludes holidays; v2 includes them).
  workingDays Decimal? @db.Decimal(8, 2)

  /// Expected leave hours under metricsRuleVersion (v2 = workingDays × fixed 8h).
  totalHours Decimal? @db.Decimal(10, 2)

  /// Frozen calculation behavior: existing rows are v1; newly created requests use v2.
  metricsRuleVersion String @default("kosovo-leave-engine.v2") @db.VarChar(64)

  isPaid         Boolean @default(true)
  affectsPayroll Boolean @default(true)

  reason           String? @db.Text
  rejectionReason String? @db.Text

  /// Art 34.2 sick-during-annual — linked interruption request (future workflow consumes).
  interruptedByLeaveRequestId String?
  interruptedBy               LeaveRequest? @relation("LeaveInterruption", fields: [interruptedByLeaveRequestId], references: [id], onDelete: SetNull)
  interruptingLeaves          LeaveRequest[] @relation("LeaveInterruption")

  /// Snapshot of superseded metrics when leave converted/interrupted (audit).
  supersedesWorkingDaysSnapshot Json?

  decidedAt DateTime?
  decidedByMembershipId String?
  decidedByMembership    UserCompanyMembership? @relation("LeaveDecidedBy", fields: [decidedByMembershipId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdBy       User?   @relation("LeaveCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  documents LeaveDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, status])
  @@index([companyId, type])
  @@index([startDate])
  @@index([endDate])
  @@index([employeeId, startDate])
  @@map("leave_requests")
}

model LeaveDocument {
  id String @id @default(cuid())

  leaveRequestId String
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  generatedDocumentId String
  artifact            DocumentGenerationArtifact @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([leaveRequestId, generatedDocumentId])
  @@index([generatedDocumentId])
  @@map("leave_documents")
}

// -----------------------------------------------------------------------------
// Terminations
// -----------------------------------------------------------------------------

model Termination {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type   TerminationType
  status TerminationStatus @default(DRAFT)

  terminationDate DateTime
  noticeDate      DateTime?
  lastWorkingDay  DateTime

  noticeDays     Int?
  severanceAmount Decimal? @db.Decimal(14, 2)

  reason  String? @db.Text
  details String? @db.Text

  finalPayrollRequired Boolean @default(true)

  finalPayrollId String?
  finalPayroll   Payroll? @relation("TerminationFinalPayroll", fields: [finalPayrollId], references: [id], onDelete: SetNull)

  generatedDocumentId String?
  generatedDocument   DocumentGenerationArtifact? @relation("TerminationGeneratedDocument", fields: [generatedDocumentId], references: [id], onDelete: SetNull)

  approvedById String?
  approvedBy   User?     @relation("TerminationApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  createdById String?
  createdBy   User?     @relation("TerminationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employmentPeriods EmploymentPeriod[]

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, status])
  @@index([companyId, type])
  @@index([companyId, terminationDate])
  @@map("terminations")
}

// -----------------------------------------------------------------------------
// Reports (definitions + async jobs)
// -----------------------------------------------------------------------------

model ReportDefinition {
  id String @id @default(cuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String // stable identifier e.g. PAYROLL_REGISTER_MONTHLY
  displayName String
  description String?

  defaultFormat ReportOutputFormat @default(PDF)

  /// Parameter schema version for UI rendering / validation
  parameterSchema Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs ReportJob[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("report_definitions")
}

model ReportJob {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  definitionId String
  definition   ReportDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)

  status ReportJobStatus @default(QUEUED)

  format ReportOutputFormat

  parameters Json?

  artifactUrl String?
  errorMessage String? @db.Text

  requestedByUserId String?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([definitionId])
  @@map("report_jobs")
}

/// Archived operational export from Raportet (Excel/PDF/CSV blobs in company asset storage).
model GeneratedReport {
  id String @id @default(cuid())

  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  reportType ReportType @map("report_type")
  title      String

  storageKey       String
  generatedFileUrl String @map("file_url")

  fileFormat ReportOutputFormat @map("file_format")

  filtersJson Json @map("filters_json")

  generatedByUserId String? @map("generated_by")
  generatedBy       User?   @relation("GeneratedReportAuthor", fields: [generatedByUserId], references: [id], onDelete: SetNull)

  generatedAt DateTime @default(now()) @map("generated_at")

  isArchived Boolean   @default(false) @map("is_archived")
  archivedAt DateTime? @map("archived_at")

  rowCount         Int?
  previewTruncated Boolean @default(false)

  filterPayrollId    String? @map("filter_payroll_id")
  filterYear         Int?    @map("filter_year")
  filterMonth        Int?    @map("filter_month")
  filterDepartmentId String? @map("filter_department_id")
  filterEmployeeId   String? @map("filter_employee_id")

  exportLogs ReportExportLog[]

  @@index([companyId])
  @@index([companyId, reportType])
  @@index([companyId, generatedAt])
  @@index([fileFormat])
  @@index([companyId, isArchived])
  @@index([companyId, filterPayrollId])
  @@index([companyId, filterYear, filterMonth])
  @@map("generated_reports")
}

model ReportExportLog {
  id String @id @default(cuid())

  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  generatedReportId String @map("generated_report_id")
  generatedReport   GeneratedReport @relation(fields: [generatedReportId], references: [id], onDelete: Cascade)

  action ReportExportAction

  performedByUserId String? @map("performed_by")
  performedBy       User?   @relation("ReportExportLogActor", fields: [performedByUserId], references: [id], onDelete: SetNull)

  performedAt DateTime @default(now()) @map("performed_at")

  metadataJson Json? @map("metadata_json")

  @@index([companyId])
  @@index([companyId, generatedReportId, performedAt])
  @@map("report_export_logs")
}

// -----------------------------------------------------------------------------
// Employee timeline & notifications (operational visibility)
// -----------------------------------------------------------------------------

model EmployeeTimelineEvent {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  occurredAt DateTime @default(now())

  /// Stable code e.g. CONTRACT_GENERATED, LEAVE_APPROVED, PAYROLL_LOCKED
  eventType String

  severity TimelineEventSeverity?

  subjectKind String?
  subjectId   String?

  title String
  body  String? @db.Text

  metadata Json?

  actorUserId String?
  actor       User? @relation("TimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  actorMembershipId String?
  actorMembership   UserCompanyMembership? @relation("TimelineActorMembership", fields: [actorMembershipId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId, employeeId, occurredAt(sort: Desc)])
  @@index([companyId, eventType, occurredAt])
  @@map("employee_timeline_events")
}

model NotificationOutbox {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  targetUserId String?
  targetUser   User?   @relation("NotificationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  channel NotificationChannel
  topic   NotificationTopic

  payload Json

  scheduledFor DateTime
  processedAt  DateTime?

  attempts  Int    @default(0)
  lastError String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, topic, scheduledFor])
  @@map("notification_outbox")
}

model NotificationPreference {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  channels      Json?
  mutedTopics   Json?
  digestFrequency String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("notification_preferences")
}

/// HR-readable activity feed (diff-sized payloads); pair with AuditLog for technical CRUD trails.
model DomainActivity {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  entityType String
  entityId   String

  verb DomainActivityVerb

  actorUserId String?
  actor       User?   @relation("DomainActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  occurredAt DateTime @default(now())

  summary String
  payload Json?

  @@index([companyId, occurredAt])
  @@index([entityType, entityId])
  @@map("domain_activities")
}

// -----------------------------------------------------------------------------
// Audit log (entity mutations — complement Prisma timestamps)
// -----------------------------------------------------------------------------

model AuditLog {
  id String @id @default(cuid())

  actorUserId String?
  actor       User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  companyId String?

  entityType String // e.g. Payroll, PayrollEntry
  entityId   String

  action String
  /// CREATE, UPDATE, DELETE, LOCK, UNLOCK, APPROVE, REJECT — align with application constants.

  diff Json?

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
