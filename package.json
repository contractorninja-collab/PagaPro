{
  "name": "pagapro",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "predev": "prisma generate",
    "dev": "next dev",
    "dev:clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (_) {}\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:sync": "prisma db push && prisma db seed",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "powershell -ExecutionPolicy Bypass -File scripts/dev-db-setup.ps1",
    "db:fix-permissions": "powershell -ExecutionPolicy Bypass -File scripts/fix-db-permissions.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "atk:template:placeholder": "node scripts/write-atk-placeholder-template.cjs",
    "contracts:validate-templates": "node scripts/validate-contract-templates.cjs",
    "contracts:seed": "node -e \"require('dotenv').config({override:true});const {PrismaPg}=require('@prisma/adapter-pg');const {PrismaClient}=require('@prisma/client');const {seedContractTemplates}=require('./scripts/seed-contract-templates.cjs');const p=new PrismaClient({adapter:new PrismaPg({connectionString:process.env.DATABASE_URL})});seedContractTemplates(p).finally(()=>p.$disconnect());\"",
    "leave:seed": "node -e \"require('dotenv').config({override:true});const {PrismaPg}=require('@prisma/adapter-pg');const {PrismaClient}=require('@prisma/client');const {seedLeaveTemplates}=require('./scripts/seed-leave-templates.cjs');const p=new PrismaClient({adapter:new PrismaPg({connectionString:process.env.DATABASE_URL})});seedLeaveTemplates(p).finally(()=>p.$disconnect());\"",
    "termination:seed": "node -e \"require('dotenv').config({override:true});const {PrismaPg}=require('@prisma/adapter-pg');const {PrismaClient}=require('@prisma/client');const {seedTerminationTemplates}=require('./scripts/seed-termination-templates.cjs');const p=new PrismaClient({adapter:new PrismaPg({connectionString:process.env.DATABASE_URL})});seedTerminationTemplates(p).finally(()=>p.$disconnect());\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "decimal.js": "^10.6.0",
    "docxtemplater": "^3.53.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.503.0",
    "next": "^15.3.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pizzip": "^3.1.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.4.2",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
